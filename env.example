# Database Configuration (Supabase Postgres)
DATABASE_URL="postgres://postgres.xxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgres://postgres.xxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Next-Auth Configuration (Auth.js)
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret"

# Google OAuth Providers
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
